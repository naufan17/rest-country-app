generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id          Int      @id @default(autoincrement())
  cca3        String   @unique
  name        String
  capital     String?
  region      String?
  flagUrl     String?
  population  Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  count     Int
  syncedAt  DateTime @default(now())
}

