generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id          Int      @id @default(autoincrement())
  cca3        String   @unique
  name        String
  capital     String?
  region      String?
  flagUrl     String?
  population  Int?
  
  // Internal Metadata
  createdAt   DateTime @default(now())   // Represents "Created"
  updatedAt   DateTime @updatedAt       // Represents "Taken" (Last Synced)
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  count     Int
  syncedAt  DateTime @default(now())
}

